DJANGO_SECRET_KEY=change-me-in-production
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=3600
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
ATONIXCORP_API_ENVIRONMENT=sandbox

# Production baseline: set DJANGO_DEBUG=False, replace DJANGO_SECRET_KEY with a
# random value of at least 50 characters, and restrict hosts/origins to your domains.
# DJANGO_ALLOWED_HOSTS=api.atonixcorp.com,atonixcorp.com,www.atonixcorp.com
# CORS_ALLOWED_ORIGINS=https://atonixcorp.com,https://www.atonixcorp.com
# CSRF_TRUSTED_ORIGINS=https://atonixcorp.com,https://www.atonixcorp.com
# FRONTEND_BASE_URL=https://atonixcorp.com
# DJANGO_SECURE_SSL_REDIRECT=True

# Required for encrypted bank and aggregator credentials.
BANKING_TOKEN_ENCRYPTION_KEY=replace-with-a-strong-random-secret

# Workspace binary files are encrypted before being written to the configured
# Django storage backend. Use a unique Fernet key in the secret manager.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKSPACE_FILE_ENCRYPTION_KEY=
# HMAC signing key for tamper-evident governance YAML. Store only in the
# deployment secret manager and rotate through the governance recovery process.
GOVERNANCE_SIGNING_KEY=
WORKSPACE_FILE_MAX_BYTES=26214400
# Set to storages.backends.s3.S3Storage for AWS S3; credentials stay in the secret manager.
WORKSPACE_FILE_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Governance cloud-export tenant OAuth. These values belong in the deployment
# secret manager. Short-lived Google/Microsoft access tokens are provided only
# at export time and are never stored by AtonixCorp.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://atonixcorp.com/integrations/google/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=
MICROSOFT_OAUTH_REDIRECT_URI=https://atonixcorp.com/integrations/microsoft/callback

# Public URL used by your provider dashboard when configuring callback and webhook targets.
BANKING_PUBLIC_BASE_URL=http://localhost:8000

# Nightly fallback sync cadence in seconds. 86400 = 24 hours.
BANKING_SYNC_INTERVAL_SECONDS=86400
ENABLE_BANKING_SYNC_SCHEDULER=1

# Banking webhook endpoints
# Plaid webhook: ${BANKING_PUBLIC_BASE_URL}/api/banking-integrations/webhooks/plaid/
# Yodlee webhook: ${BANKING_PUBLIC_BASE_URL}/api/banking-integrations/webhooks/yodlee/
# Finicity webhook: ${BANKING_PUBLIC_BASE_URL}/api/banking-integrations/webhooks/finicity/

# Plaid OAuth / Link credentials
PLAID_CLIENT_ID=
PLAID_CLIENT_SECRET=
PLAID_OAUTH_AUTHORIZE_URL=

# Yodlee OAuth credentials
YODLEE_CLIENT_ID=
YODLEE_CLIENT_SECRET=
YODLEE_OAUTH_AUTHORIZE_URL=

# Finicity OAuth credentials
FINICITY_CLIENT_ID=
FINICITY_CLIENT_SECRET=
FINICITY_OAUTH_AUTHORIZE_URL=

# Hybrid AI / Claude integration
AI_ENABLE_EXTERNAL_MODELS=0
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
CLAUDE_OPUS_MODEL=claude-opus-4-1
CLAUDE_SONNET_MODEL=claude-sonnet-4-0
AI_DEFAULT_MAX_TOKENS=2000

# Brevo transactional SMTP. Keep EMAIL_HOST_PASSWORD in a secret manager or
# untracked local .env file; never commit a Brevo SMTP key.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=b2acdf001@smtp-brevo.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@atonixcorp.com
ORGANIZATION_EMAIL_DOMAIN=atonixcorp.com
