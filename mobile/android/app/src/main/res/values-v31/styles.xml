<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) splash screen theme overrides.
  The system splash screen uses windowSplashScreen* attributes.
-->
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <!-- Splash screen background — brand primary navy -->
        <item name="android:windowSplashScreenBackground">@color/brand_primary</item>
        <!-- Centered icon on the splash screen (72dp inside 108dp canvas) -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- No branding image — minimal, clean, institutional -->
        <item name="android:windowSplashScreenIconBackgroundColor">@color/brand_primary</item>
    </style>
</resources>
