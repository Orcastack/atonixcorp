<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer — AtonixCorp shield mark v2.

  Viewport: 108×108dp  (Android adaptive icon spec)
  Safe zone: central 72×72dp  (margin = 18dp each side)

  Source: 64×64 SVG paths scaled by (72/64 = 1.125) and offset by 18dp.
  New design: white shield + EE6C4D inner stroke on EE6C4D background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White shield body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,31.5 L74.25,38.9 V56.25
                          C74.25,67.5 66.75,77.25 54,83.25
                          C41.25,77.25 33.75,67.5 33.75,56.25
                          V38.9 Z"/>

    <!-- EE6C4D inner border ring (matches background, creates cutout effect) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#EE6C4D"
        android:strokeWidth="1.7"
        android:pathData="M54,37.1 L70.9,43.9 V56.25
                          C70.9,65.9 64.8,74.4 54,80.1
                          C43.2,74.4 37.1,65.9 37.1,56.25
                          V43.9 Z"/>

</vector>
